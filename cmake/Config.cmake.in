@PACKAGE_INIT@

# Backend that was used to build this library
set(TritonJIT_BACKEND "@BACKEND@")

# Leave Public Dependency Resolution Later
include(CMakeFindDependencyMacro)

# Backend-specific dependencies
if(TritonJIT_BACKEND STREQUAL "CUDA" OR TritonJIT_BACKEND STREQUAL "IX")
    find_dependency(CUDAToolkit REQUIRED)
elseif(TritonJIT_BACKEND STREQUAL "NPU")
    # Create Ascend imported targets for downstream projects
    set(_ASCEND_TOOLKIT_HOME $ENV{ASCEND_TOOLKIT_HOME})
    if(NOT _ASCEND_TOOLKIT_HOME)
        set(_ASCEND_TOOLKIT_HOME "/usr/local/Ascend/ascend-toolkit/latest")
    endif()

    # Find CANN installation for runtime headers
    set(_CANN_HOME $ENV{CANN_HOME})
    if(NOT _CANN_HOME)
        file(GLOB _CANN_CANDIDATES "/usr/local/Ascend/cann-*")
        if(_CANN_CANDIDATES)
            list(GET _CANN_CANDIDATES 0 _CANN_HOME)
        endif()
    endif()

    # Detect architecture
    if(CMAKE_SYSTEM_PROCESSOR MATCHES "aarch64")
        set(_ASCEND_ARCH_DIR "aarch64-linux")
    else()
        set(_ASCEND_ARCH_DIR "x86_64-linux")
    endif()

    if(EXISTS ${_ASCEND_TOOLKIT_HOME})
        find_library(_ASCENDCL_LIBRARY ascendcl PATHS ${_ASCEND_TOOLKIT_HOME}/lib64 NO_DEFAULT_PATH)
        if(_ASCENDCL_LIBRARY AND NOT TARGET Ascend::ascendcl)
            # Build include directories list
            set(_ASCEND_INCLUDE_DIRS "${_ASCEND_TOOLKIT_HOME}/include")
            if(_CANN_HOME AND EXISTS "${_CANN_HOME}/${_ASCEND_ARCH_DIR}/pkg_inc")
                list(APPEND _ASCEND_INCLUDE_DIRS "${_CANN_HOME}/${_ASCEND_ARCH_DIR}/pkg_inc")
            endif()

            add_library(Ascend::ascendcl SHARED IMPORTED)
            set_target_properties(Ascend::ascendcl PROPERTIES
                IMPORTED_LOCATION ${_ASCENDCL_LIBRARY}
                INTERFACE_INCLUDE_DIRECTORIES "${_ASCEND_INCLUDE_DIRS}"
            )
        endif()
    endif()
endif()

list(APPEND CMAKE_MODULE_PATH "${CMAKE_CURRENT_LIST_DIR}")
find_dependency(Torch MODULE REQUIRED)

find_dependency(fmt)
if (NOT TARGET fmt::fmt)
  # use the fmt installed along with TritonJIT
  find_dependency(fmt REQUIRED PATHS "${CMAKE_CURRENT_LIST_DIR}/../fmt")
endif()

if (NOT TARGET TritonJIT::triton_jit)
  include("${CMAKE_CURRENT_LIST_DIR}/TritonJITTargets.cmake")
endif()

check_required_components(TritonJIT)
